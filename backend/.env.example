APP_ENV=local
APP_TIMEZONE=Asia/Kolkata
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
DATABASE_URL=postgresql+asyncpg://adhikarai:adhikarai@localhost:5432/adhikarai
DATABASE_DIRECT_URL=postgresql+asyncpg://adhikarai:adhikarai@localhost:5432/adhikarai
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=300
ADMIN_API_TOKEN=change-me
ELIGIBILITY_ENGINE=experta
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-small
FAISS_INDEX_DIR=./data/faiss
ENABLE_SCHEDULER=true
EXPIRY_CHECK_CRON=0 2 * * *
MYSCHEME_API_BASE_URL=
MYSCHEME_API_TOKEN=
MYSCHEME_INGESTION_MODE=json_file
INGESTION_AUTO_PUBLISH=false
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=2592000
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=qwen2.5:7b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=512
AGENT_JSON_REPAIR_RETRIES=1
AGENT_MAX_QUESTIONS_BEFORE_RESULT=8
AGENT_TIMEOUT_SECONDS=20
