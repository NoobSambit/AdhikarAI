APP_ENV=local
APP_TIMEZONE=Asia/Kolkata
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DATABASE_URL=postgresql+asyncpg://adhikarai:adhikarai@localhost:5432/adhikarai
DATABASE_DIRECT_URL=postgresql+asyncpg://adhikarai:adhikarai@localhost:5432/adhikarai
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=2
DB_POOL_TIMEOUT=10
DB_POOL_RECYCLE=300
ADMIN_API_TOKEN=change-me
ELIGIBILITY_ENGINE=experta
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=intfloat/multilingual-e5-small
FAISS_INDEX_DIR=./data/faiss
ENABLE_SCHEDULER=true
EXPIRY_CHECK_CRON=0 2 * * *
MYSCHEME_API_BASE_URL=
MYSCHEME_API_TOKEN=
MYSCHEME_INGESTION_MODE=json_file
INGESTION_AUTO_PUBLISH=false
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=2592000
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_FALLBACK_MODEL=qwen2.5:7b
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=512
AGENT_JSON_REPAIR_RETRIES=1
AGENT_MAX_QUESTIONS_BEFORE_RESULT=8
AGENT_TIMEOUT_SECONDS=20
VOICE_PROVIDER=local
ASR_MIN_CONFIDENCE=0.70
VOICE_MAX_UTTERANCE_SECONDS=20
VOICE_MAX_UPLOAD_MB=8
BROWSER_ASR_FALLBACK_AFTER_MS=2000
NEXT_PUBLIC_SILENCE_MS=1500
NEXT_PUBLIC_SILENCE_THRESHOLD=0.018
GROQ_WHISPER_MODEL=whisper-large-v3-turbo
GROQ_AUDIO_TRANSCRIPTIONS_URL=https://api.groq.com/openai/v1/audio/transcriptions
WHISPER_CPP_BINARY=/opt/whisper.cpp/build/bin/whisper-cli
WHISPER_CPP_MODEL_PATH=/models/ggml-large-v3.bin
WHISPER_CPP_ARGS=-l auto -otxt -ojf --print-progress false --no-timestamps
ASR_TIMEOUT_SECONDS=12
TRANSLATION_PROVIDER=local_indictrans2
TRANSLATION_SERVICE_URL=http://localhost:8001
AI4BHARAT_TRANSLATE_URL=
AI4BHARAT_API_KEY=
AI4BHARAT_TIMEOUT_SECONDS=3
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_TRANSLATE_URL=https://translation.googleapis.com/language/translate/v2
TTS_PROVIDER=local_indictts
LOCAL_TTS_URL=http://localhost:8002
LOCAL_TTS_TIMEOUT_SECONDS=8
GOOGLE_TTS_URL=https://texttospeech.googleapis.com/v1/text:synthesize
GOOGLE_APPLICATION_CREDENTIALS=
TTS_CACHE_TTL_SECONDS=86400
TRANSLATION_CACHE_TTL_SECONDS=604800
STORE_AUDIO_DEBUG=false
AUTH_JWT_SECRET=change-me-phase-4
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_NAME=adhikarai_session
AUTH_JWT_TTL_SECONDS=2592000
OTP_PROVIDER=mock
OTP_EXPIRY_SECONDS=300
OTP_RETRY_AFTER_SECONDS=30
OTP_MAX_ATTEMPTS=5
MSG91_BASE_URL=https://control.msg91.com/api/v5
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
DASHBOARD_ENABLED=true
DASHBOARD_SESSION_IDLE_TIMEOUT_SECONDS=3600
RATE_LIMIT_USER_PER_DAY=100
RATE_LIMIT_OPERATOR_PER_DAY=1000
RATE_LIMIT_GUEST_PER_DAY=50
EXPORT_STORAGE_PROVIDER=local
EXPORT_MAX_ROWS=5000
BULK_ELIGIBILITY_MAX_ROWS=500
BULK_ELIGIBILITY_MAX_MB=2
SMS_NOTIFICATIONS_ENABLED=false
MSG91_SMS_TEMPLATE_ID=
QUALITY_MONITOR_CRON=0 * * * *
SCHEME_EXPIRY_WARNING_DAYS=30
